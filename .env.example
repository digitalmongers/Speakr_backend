# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/patel-properties

# Logging Configuration
LOG_LEVEL=debug
PERSISTENT_LOGS=false

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SendGrid Configuration
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=info@digitalmongers.com
SENDGRID_FROM_NAME=Speakr
OWNER_EMAIL=info@digitalmongers.com

# Mailgun Configuration (Fallback)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILGUN_HOST=api.mailgun.net

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_S3_SIGNED_URL_EXPIRES=3600
